rules_version = '2';

/**
 * Firestore Security Rules for SitePilot Multi-Tenant Architecture
 * 
 * CRITICAL: These rules enforce strict tenant isolation
 * Each tenant's data is completely isolated from other tenants
 * 
 * Structure (Human-Readable):
 * /tenants/{tenantSlug}/sites/{websiteSlug}/...
 * 
 * Deploy these rules using Firebase CLI:
 * firebase deploy --only firestore:rules
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function: Check if user belongs to tenant
    function belongsToTenant(tenantSlug) {
      return isAuthenticated() && 
             request.auth.token.tenantSlug == tenantSlug;
    }
    
    // Helper function: Validate tenant slug in document
    function hasValidTenantSlug(tenantSlug) {
      return request.resource.data.tenantSlug == tenantSlug;
    }
    
    // Root level - deny all direct access
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Tenant collection - isolated per tenant
    match /tenants/{tenantSlug} {
      // Only allow read if user belongs to tenant
      allow read: if belongsToTenant(tenantSlug);
      
      // Only backend service account can write
      allow write: if false;
      
      // Sites subcollection
      match /sites/{websiteSlug} {
        // Allow read if user belongs to tenant
        allow read: if belongsToTenant(tenantSlug);
        
        // Only backend service account can write
        allow write: if false;
        
        // Pages subcollection - public read for all pages
        match /pages/{pageSlug} {
          // Public read access for all pages
          allow read: if true;
          
          // Only backend can write
          allow write: if false;
        }
        
        // Contact form submissions - allow public submissions
        match /contact_form_submissions/{submissionId} {
          // Allow read if user belongs to tenant
          allow read: if belongsToTenant(tenantSlug);
          
          // Allow form submissions (must include tenantSlug and websiteSlug)
          allow create: if hasValidTenantSlug(tenantSlug) &&
                          request.resource.data.websiteSlug == websiteSlug &&
                          request.resource.data.submittedAt is timestamp;
          
          // No updates or deletes from client
          allow update, delete: if false;
        }
        
        // Analytics subcollection
        match /analytics/{analyticsId} {
          // Allow read if user belongs to tenant
          allow read: if belongsToTenant(tenantSlug);
          
          // Allow analytics events (must include tenantSlug and websiteSlug)
          allow create: if hasValidTenantSlug(tenantSlug) &&
                          request.resource.data.websiteSlug == websiteSlug &&
                          request.resource.data.timestamp is timestamp;
          
          // No updates or deletes from client
          allow update, delete: if false;
        }
        
        // Dynamic content subcollection
        match /content/{contentId} {
          // Public read for published content
          allow read: if true;
          
          // Only backend can write
          allow write: if false;
        }
      }
    }
    
    // Admin collection - only accessible by backend service account
    match /admin/{document=**} {
      allow read, write: if false;
    }
    
    // System collection - only accessible by backend service account
    match /system/{document=**} {
      allow read, write: if false;
    }
  }
}

/**
 * DEPLOYMENT INSTRUCTIONS:
 * 
 * 1. Install Firebase CLI:
 *    npm install -g firebase-tools
 * 
 * 2. Login to Firebase:
 *    firebase login
 * 
 * 3. Initialize Firebase in your project:
 *    firebase init firestore
 * 
 * 4. Copy this file to firestore.rules in your project root
 * 
 * 5. Deploy rules:
 *    firebase deploy --only firestore:rules
 * 
 * 6. Verify rules in Firebase Console:
 *    https://console.firebase.google.com/project/YOUR_PROJECT/firestore/rules
 * 
 * TESTING:
 * 
 * Use Firebase Emulator Suite for local testing:
 * firebase emulators:start --only firestore
 * 
 * SECURITY NOTES:
 * 
 * - All tenant data is isolated by tenantSlug (human-readable)
 * - Cross-tenant reads/writes are impossible
 * - Public pages are readable by anyone
 * - Form submissions require valid tenantSlug and websiteSlug
 * - Only backend service account can write to most collections
 * - Custom auth tokens should include tenantSlug claim
 * 
 * HUMAN-READABLE STRUCTURE:
 * 
 * Instead of:
 *   /tenants/69993d6bb884dbbbef3b93f1/sites/69999b6da7bc698c6913452d/submissions/ClGVGXEo8O2iYO05L0Dv
 * 
 * Now:
 *   /tenants/acme-corp/sites/coffee-shop-website/contact_form_submissions/john-doe-1234567890
 * 
 * This makes it much easier to:
 * - Navigate Firestore Console
 * - Debug issues
 * - Understand data structure
 * - Manually verify submissions
 */
